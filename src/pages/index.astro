---
// Landing page — custom page, intentionally not the Starlight docs layout.
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/ibm-plex-sans/700.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/600.css';

const quickstart = `{
  "mcpServers": {
    "dataverse-ops": {
      "command": "npx",
      "args": ["-y", "@simplesmoothsafe/dataverse-ops-mcp"],
      "env": {
        "DATAVERSE_URL": "https://yourorg.crm.dynamics.com",
        "CLIENT_ID": "<app-registration-client-id>",
        "CLIENT_SECRET": "<client-secret>",
        "TENANT_ID": "<entra-tenant-id>"
      }
    }
  }
}`;

// Grouped for the landing page so the three pillars — plug-ins, flows,
// governance — read at a glance. `ping` (a trivial health check with no doc
// page) is mentioned in the note under the table rather than listed here.
const toolGroups = [
  {
    name: 'Plug-in & job diagnostics',
    tools: [
      ['get_plugin_traces', 'Free', 'Recent plug-in trace logs, defaulting to executions that threw exceptions.', '/tools/get_plugin_traces/'],
      ['get_failed_async_jobs', 'Free', 'Failed and canceled async jobs over a window, grouped by name and error code.', '/tools/get_failed_async_jobs/'],
      ['find_stuck_jobs', 'Free', 'Async jobs stuck in waiting or in-progress beyond a threshold (postponed jobs excluded).', '/tools/find_stuck_jobs/'],
      ['check_step_config', 'Free', 'Lints plug-in step registrations: missing filtering attributes, risky sync steps, rank collisions.', '/tools/check_step_config/'],
      ['explain_trace', 'Free', 'Root-cause analysis of a single failing plug-in execution, with correlated sibling traces.', '/tools/explain_trace/'],
      ['analyze_plugin_performance', 'Free', 'Per-plugin performance table (p50/p95, sync vs async, depth) with anti-pattern flags.', '/tools/analyze_plugin_performance/'],
    ],
  },
  {
    name: 'Power Automate flows',
    tools: [
      ['get_flow_runs', 'Free', 'Filtered cloud-flow run history — by flow, status and time window.', '/tools/get_flow_runs/'],
      ['explain_flow_failure', 'Free', 'Root cause of a failed flow run: failed-action guess and known-pattern detection.', '/tools/explain_flow_failure/'],
      ['analyze_flow_runs', 'Free', 'Per-flow success rates, duration percentiles and error clusters, with reliability flags.', '/tools/analyze_flow_runs/'],
      ['check_flow_connections', 'Free', 'Connection-reference health: unbound references, disabled owners, owner mismatches.', '/tools/check_flow_connections/'],
      ['flow_governance_report', 'Free', 'Flow inventory by state and owner: disabled owners, suspended flows, stale drafts.', '/tools/flow_governance_report/'],
      ['detect_automation_loops', 'Free', 'Suspected trigger→write cycles between cloud flows (self-loops and short cycles).', '/tools/detect_automation_loops/'],
      ['document_flow', 'Free', 'Documents a cloud flow from its definition: triggers, action tree and connectors, plus markdown.', '/tools/document_flow/'],
    ],
  },
  {
    name: 'Solutions, tables & governance',
    tools: [
      ['get_org_automation_settings', 'Free', 'Org switches the other tools depend on: trace logging level and auditing configuration.', '/tools/get_org_automation_settings/'],
      ['explain_import_failure', 'Free', 'Explains a failed solution import with per-component causes and missing dependencies.', '/tools/explain_import_failure/'],
      ['what_runs_on_table', 'Free', 'Everything registered on one table: plug-in steps, flows, classic workflows and business rules.', '/tools/what_runs_on_table/'],
      ['document_table', 'Free', 'Table documentation from metadata: columns, relationships, keys and attached automation.', '/tools/document_table/'],
      ['get_solution_layers', 'Free', 'Solution layering for one component — who overwrote it and whether an Active layer blocks updates.', '/tools/get_solution_layers/'],
      ['modernization_report', 'Free', 'Legacy automation inventory: dialogs, classic workflows and business rules, with migration priorities.', '/tools/modernization_report/'],
    ],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dataverse Ops MCP — Dataverse &amp; Power Automate diagnostics inside your AI assistant</title>
    <meta
      name="description"
      content="Plug-in trace root-cause analysis, async job triage, Power Automate flow diagnostics, and solution and automation governance for Microsoft Dataverse — over MCP/stdio. Data never leaves your tenant."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Cloudflare Web Analytics (privacy-friendly, no cookies).
         Owner: replace REPLACE_WITH_CF_ANALYTICS_TOKEN with your real token. -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "REPLACE_WITH_CF_ANALYTICS_TOKEN"}'
      is:inline></script>
  </head>
  <body>
    <header class="nav">
      <div class="wrap nav-inner">
        <a class="brand" href="/">Dataverse&nbsp;Ops&nbsp;MCP</a>
        <nav>
          <a href="#tools">Tools</a>
          <a href="https://github.com/sss-dclemente/dataverse-mcp-pro">GitHub</a>
          <a href="/getting-started/claude-desktop/">Docs</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero wrap">
        <h1>Dataverse diagnostics inside your AI assistant</h1>
        <p class="lede">
          Plug-in trace root-cause analysis, async job triage, Power Automate flow
          diagnostics, and solution &amp; automation governance for Microsoft
          Dataverse — <strong>20 tools</strong> your assistant can call directly.
          Runs locally over <strong>MCP/stdio</strong>: no hosted service, no open
          ports, and your Dataverse data <strong>never leaves your tenant</strong>.
        </p>
        <div class="cta-row">
          <a class="btn btn-primary" href="/getting-started/claude-desktop/">Get started</a>
          <a class="btn btn-ghost" href="https://github.com/sss-dclemente/dataverse-mcp-pro">View on GitHub</a>
        </div>

        <div class="quickstart">
          <p class="quickstart-label">
            Add to Claude Desktop (<code>claude_desktop_config.json</code>):
          </p>
          <pre><code>{quickstart}</code></pre>
        </div>
      </section>

      <section id="tools" class="wrap">
        <h2>Tools</h2>
        <p>All 20 tools are free and MIT-licensed — no key, no signup. They span plug-in diagnostics, Power Automate flow diagnostics, and Dataverse governance &amp; documentation.</p>
        <div class="table-scroll">
          <table>
            <thead>
              <tr><th>Tool</th><th>What it does</th></tr>
            </thead>
            <tbody>
              {toolGroups.map((group) => (
                <Fragment>
                  <tr class="cat"><th colspan="2">{group.name}</th></tr>
                  {group.tools.map(([name, , desc, href]) => (
                    <tr>
                      <td><code><a href={href}>{name}</a></code></td>
                      <td>{desc}</td>
                    </tr>
                  ))}
                </Fragment>
              ))}
            </tbody>
          </table>
        </div>
        <p class="tools-note">
          Plus <code>ping</code>, a zero-dependency health check.
          <strong>20 tools, all free and open source.</strong>
          Every tool has a <a href="/getting-started/claude-desktop/">reference page</a> with inputs, an example call and example output.
        </p>
      </section>

      <section id="open-source" class="wrap">
        <h2>Free &amp; open source</h2>
        <p class="lede">
          Every one of the 20 tools is free, and the whole server is
          <strong>MIT-licensed</strong>. Install it, read the source, fork it, or
          open a pull request — new diagnostics and fixes for real-world Dataverse
          quirks are welcome.
        </p>
        <div class="cta-row">
          <a class="btn btn-primary" href="/getting-started/claude-desktop/">Get started</a>
          <a class="btn btn-ghost" href="https://github.com/sss-dclemente/dataverse-mcp-pro">View on GitHub</a>
        </div>
      </section>
    </main>

    <footer>
      <div class="wrap footer-inner">
        <span>© 2026 simplesmoothsafe</span>
        <nav>
          <a href="/getting-started/claude-desktop/">Docs</a>
          <a href="/changelog/">Changelog</a>
          <a href="/security/">Security</a>
          <a href="https://status.simplesmoothsafe.com">Status</a>
          <a href="mailto:support@simplesmoothsafe.com">Support</a>
        </nav>
      </div>
    </footer>

    <style>
      :root {
        --bg: #ffffff;
        --bg-soft: #f4f7f6;
        --fg: #16211f;
        --fg-muted: #4c5a57;
        --border: #d8e0de;
        --accent: #0b6a61;
        --accent-contrast: #ffffff;
        --code-bg: #0f1c1a;
        --code-fg: #d5e6e3;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #101716;
          --bg-soft: #17211f;
          --fg: #e4ecea;
          --fg-muted: #9fb0ac;
          --border: #2a3835;
          --accent: #35a89b;
          --accent-contrast: #06211e;
          --code-bg: #0b1211;
          --code-fg: #cfe0dd;
        }
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: 'IBM Plex Sans', ui-sans-serif, system-ui, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.6;
      }
      code, pre { font-family: 'IBM Plex Mono', ui-monospace, monospace; }
      a { color: var(--accent); }
      .wrap { max-width: 62rem; margin: 0 auto; padding: 0 1.25rem; }

      .nav { border-bottom: 1px solid var(--border); }
      .nav-inner {
        display: flex; align-items: center; justify-content: space-between;
        padding-top: 0.9rem; padding-bottom: 0.9rem;
      }
      .brand { font-weight: 700; color: var(--fg); text-decoration: none; }
      .nav nav a, footer nav a {
        color: var(--fg-muted); text-decoration: none; margin-left: 1.1rem;
      }
      .nav nav a:hover, footer nav a:hover { color: var(--accent); }

      .hero { padding-top: 4rem; padding-bottom: 2rem; }
      .hero h1 {
        font-size: clamp(1.9rem, 4.5vw, 3rem);
        line-height: 1.15; font-weight: 700; margin: 0 0 1rem;
        max-width: 40ch;
      }
      .lede { font-size: 1.1rem; color: var(--fg-muted); max-width: 62ch; margin: 0 0 1.5rem; }
      .lede strong { color: var(--fg); }

      .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
      .btn {
        display: inline-block; padding: 0.55rem 1.2rem; border-radius: 6px;
        text-decoration: none; font-weight: 600; border: 1px solid var(--accent);
      }
      .btn-primary { background: var(--accent); color: var(--accent-contrast); }
      .btn-ghost { color: var(--accent); background: transparent; }
      .btn:hover { filter: brightness(1.1); }

      .quickstart-label { color: var(--fg-muted); margin-bottom: 0.4rem; font-size: 0.95rem; }
      pre {
        background: var(--code-bg); color: var(--code-fg);
        border: 1px solid var(--border); border-radius: 8px;
        padding: 1rem 1.25rem; overflow-x: auto; font-size: 0.85rem; line-height: 1.5;
      }

      section { padding-top: 2.5rem; padding-bottom: 2.5rem; }
      h2 { font-size: 1.6rem; margin: 0 0 0.5rem; }

      .table-scroll { overflow-x: auto; }
      table { border-collapse: collapse; width: 100%; margin-top: 1rem; font-size: 0.95rem; }
      th, td { text-align: left; padding: 0.55rem 0.9rem; border-bottom: 1px solid var(--border); }
      th { color: var(--fg-muted); font-weight: 600; }
      tr.cat th {
        color: var(--fg); font-weight: 700; font-size: 0.9rem;
        letter-spacing: 0.01em; padding-top: 1.3rem;
      }
      .tools-note { color: var(--fg-muted); font-size: 0.9rem; margin-top: 1rem; }
      .tools-note strong { color: var(--fg); }

      footer { border-top: 1px solid var(--border); margin-top: 2rem; }
      .footer-inner {
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 0.75rem;
        padding-top: 1.25rem; padding-bottom: 1.25rem;
        color: var(--fg-muted); font-size: 0.9rem;
      }
    </style>
  </body>
</html>
